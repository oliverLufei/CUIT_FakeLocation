<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:overScrollMode="never"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="校园高精定位模拟"
            android:textColor="#333333"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- 预设地点区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- 原有地点 -->
            <Button
                android:id="@+id/btnField1"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="第一田径场\n103.986258, 30.580374"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnField2"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="第二田径场\n103.987241, 30.583477"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnGym"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="体育馆\n103.988838, 30.583366"
                android:textSize="12sp" />

            <!-- 新增地点 -->
            <Button
                android:id="@+id/btnBasketball1"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="第一篮球场\n103.985773, 30.581551"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBasketball2"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="第二篮球场\n103.985779, 30.582454"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBadminton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="羽毛球场\n103.985687, 30.583347"
                android:textSize="12sp" />

            <Button
                android:id="@+id/lquanField"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="龙泉操场\n104.305854, 30.606917"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="24dp"
            android:background="#DDDDDD" />

        <!-- 自定义坐标区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/etLon"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@android:drawable/editbox_background"
                android:hint="手动输入经度 (Longitude)"
                android:inputType="numberDecimal|numberSigned"
                android:padding="10dp"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etLat"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@android:drawable/editbox_background"
                android:hint="手动输入纬度 (Latitude)"
                android:inputType="numberDecimal|numberSigned"
                android:padding="10dp"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnApplyCustom"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:backgroundTint="#4CAF50"
                android:text="应用自定义坐标"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- 状态显示 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#EEEEEE"
            android:padding="15dp"
            android:text="当前状态: 未运行"
            android:textColor="#666666"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>